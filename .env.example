# ==============================
# Core settings
# ==============================
PROJECT_NAME=real-estate-data-platform
PYTHONUNBUFFERED=1
LOG_LEVEL=INFO

# ==============================
# S3-compatible storage
# MinIO local: set endpoint to http://minio:9000
# AWS S3: leave endpoint empty and use AWS credentials
# ==============================
S3_BUCKET=real-estate-platform
S3_REGION=us-east-1
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_SECURE=false

# Data zones in object storage
RAW_PREFIX=raw/real_estate
BRONZE_PREFIX=bronze/real_estate
SILVER_PREFIX=silver/real_estate
GOLD_PREFIX=gold/real_estate
CDC_STATE_PREFIX=state/cdc

# Ingestion behavior
DATA_SOURCE_URL=https://example.com/api/properties
REQUEST_TIMEOUT_SECONDS=30
INGESTION_MAX_RETRIES=3
INGESTION_BACKOFF_SECONDS=2

# Platform services
DAGSTER_HOME=/opt/dagster/dagster_home
SUPERSET_SECRET_KEY=replace-this-in-production
