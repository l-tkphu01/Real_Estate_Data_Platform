# ==============================
# Core settings
# ==============================
PROJECT_NAME=real-estate-data-platform
PYTHONUNBUFFERED=1
LOG_LEVEL=INFO

# Config-driven profile selection
APP_PROFILE=local.azurite
CONFIG_DIR=pipelines/config

# ==============================
# Azure Data Lake Storage / Azurite
# ==============================
AZURE_CONTAINER=real-estate-platform
AZURE_STORAGE_ACCOUNT=devstoreaccount1
# (Default local Azurite Key) Replace this for Production
AZURE_STORAGE_KEY=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==
AZURE_ENDPOINT=http://127.0.0.1:10000/devstoreaccount1

# Data zones in object storage
RAW_PREFIX=raw/real_estate
BRONZE_PREFIX=bronze/real_estate
SILVER_PREFIX=silver/real_estate
GOLD_PREFIX=gold/real_estate
CDC_STATE_PREFIX=state/cdc

# Ingestion behavior
DATA_SOURCE_URL=https://example.com/api/properties
REQUEST_TIMEOUT_SECONDS=30
INGESTION_MAX_RETRIES=3
INGESTION_BACKOFF_SECONDS=2

# Platform services
DAGSTER_HOME=/opt/dagster/dagster_home
SUPERSET_SECRET_KEY=replace-this-in-production
